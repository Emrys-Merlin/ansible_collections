[program:prometheus]
command=prometheus
  --web.listen-address=0.0.0.0:9090
  --config.file=%(ENV_HOME)s/etc/prometheus/prometheus.yml
  --storage.tsdb.path=%(ENV_HOME)s/var/lib/prometheus/
  --storage.tsdb.retention=15d
  --web.external-url=https://timadler.uber.space/prometheus
  --web.route-prefix=/prometheus
autostart=yes
autorestart=yes
# `startsecs` is set by Uberspace monitoring team, to prevent a broken service from looping
startsecs=30
