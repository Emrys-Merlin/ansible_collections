# Managed by Ansible (emrys_merlin.rpi.victoria_metrics). Do not edit by hand.
global:
  scrape_interval: {{ victoria_metrics_scrape_interval }}
scrape_configs:
  - job_name: homeassistant
    scheme: {{ victoria_metrics_ha_scheme }}
    metrics_path: /api/prometheus
    bearer_token: "{{ victoria_metrics_ha_token }}"
    static_configs:
      - targets:
          - "{{ victoria_metrics_ha_host }}:{{ victoria_metrics_ha_port }}"
    metric_relabel_configs:
      - source_labels: [__name__]
        regex: "{{ victoria_metrics_ha_keep_metrics | join('|') }}"
        action: keep
